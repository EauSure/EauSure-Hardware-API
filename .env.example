# Example environment variables for EauSure Hardware API

NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Shared auth secret used to verify user JWTs
JWT_SECRET=replace_with_shared_jwt_secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/water-quality-monitor
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000

# Gateway firmware API key
GATEWAY_API_KEY=replace_with_gateway_api_key

# MQTT
MQTT_BROKER_URL=mqtt://broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=water-quality-api
MQTT_PUBLISH_TOPIC=water-quality/live-data
MQTT_QOS=1

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=100
RATE_LIMIT_MAX_REQUESTS=300
